{
  "manifestVersion": 6,
  "id": "com.helperharry.indesign",
  "name": "Helper Harry",
  "version": "1.0.0",
  "main": "index.html",
  "icons": [
    { "width": 24, "height": 24, "path": "icons/icon-24.png", "scale": [1, 2], "theme": ["all"], "species": ["pluginList"] },
    { "width": 48, "height": 48, "path": "icons/icon-48.png", "scale": [1, 2], "theme": ["all"], "species": ["pluginList"] },
    { "width": 96, "height": 96, "path": "icons/icon-96.png", "scale": [1, 2], "theme": ["all"], "species": ["pluginList"] }
  ],
  "host": [
    {
      "app": "ID",
      "minVersion": "18.0"
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "hhPanel",
      "label": "Helper Harry",
      "minimumSize": { "width": 280, "height": 400 },
      "maximumSize": { "width": 400, "height": 2000 },
      "preferredDockedSize": { "width": 300, "height": 600 }
    }
  ],
  "requiredPermissions": {
    "network": {
      "domains": [
        "https://app.helperharry.com",
        "https://*.r2.cloudflarestorage.com"
      ]
    },
    "localFileSystem": "fullAccess",
    "clipboard": "readAndWrite",
    "launchProcess": {
      "schemes": ["file"],
      "extensions": []
    }
  }
}
